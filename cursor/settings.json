{
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit",
		"source.fixAll.biome": "explicit",
		"source.fixAll.ts": "explicit",
		"source.organizeImports.biome": "explicit"
	},
	"editor.formatOnSave": true,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmDelete": false,
	"tailwindCSS.experimental.classRegex": [
		["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
		["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
		["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
		["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
	],

	"[astro]": {
		"editor.defaultFormatter": "astro-build.astro-vscode"
	},
	"typescript.updateImportsOnFileMove.enabled": "always",
	"svg.preview.mode": "svg",
	"git.confirmSync": false,
	"python.createEnvironment.trigger": "off",
	"cursor.cpp.disabledLanguages": ["plaintext", "scminput"],
	"redhat.telemetry.enabled": false,
	"git.autofetch": true,
	"parameterHints.hintingType": "typeOnly",
	"[svg]": {
		"editor.defaultFormatter": "jock.svg"
	},
	"javascript.updateImportsOnFileMove.enabled": "always",

	"files.associations": {
		"*.css": "tailwindcss"
	},

	"terminal.integrated.commandsToSkipShell": ["matlab.interrupt"],
	"terminal.integrated.profiles.osx": {
		"zsh": {
			"path": "zsh",
			"macOptionIsMeta": true
		}
	},
	"MATLAB.installPath": "/Applications/MATLAB_R2025a.app",
	"workbench.colorTheme": "Monokai Pro (Filter Machine)",
	// "[typescriptreact]": {
	//   "editor.defaultFormatter": "biomejs.biome"
	// },
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"workbench.iconTheme": "Monokai Pro (Filter Machine) Icons",
	"editor.minimap.enabled": true,

	"[markdown]": {
		"editor.defaultFormatter": "yzhang.markdown-all-in-one"
	},
	"[dockercompose]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"workbench.tree.indent": 24,
	"workbench.view.alwaysShowHeaderActions": true,
	"notebook.cellExecutionTimeVerbosity": "verbose",
	"notebook.diff.overviewRuler": true,
	"notebook.markup.fontSize": 10,
	"notebook.output.fontFamily": "JetBrains Mono",
	"jupyter.askForKernelRestart": false,
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"editor.codeLensFontSize": 10,
	"editor.fontSize": 11,
	"[matlab]": {
		"editor.defaultFormatter": "MathWorks.language-matlab"
	},
	"cursor.composer.shouldChimeAfterChatFinishes": true,
	"cursor.cpp.enablePartialAccepts": true,
	"diffEditor.ignoreTrimWhitespace": true,
	"workbench.editorAssociations": {
		"*.svg": "default"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"claudeCode.preferredLocation": "panel",
	"[csharp]": {
		"editor.defaultFormatter": "JetBrains.resharper-code"
	},
	"resharper.region.region": "MiddleEast",
	"resharper.dataSharing.allowDataSharing": false,
	"window.autoDetectColorScheme": false,
	"editor.unicodeHighlight.ambiguousCharacters": false
}
